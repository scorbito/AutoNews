# 메일 계정 접속 정보 — 실제 값은 .env 에 채우세요 (.env 는 git 에 올리지 마세요)
# 비밀번호는 로그인 비번이 아니라 "앱 비밀번호"여야 할 가능성이 높습니다.

# --- 네이버 ---
NAVER_EMAIL=your_id@naver.com
NAVER_PASSWORD=app_password_here
# 수집할 폴더(쉼표 구분). 비우면 코드 기본값 '내게쓴메일함'
NAVER_FOLDERS=내게쓴메일함

# --- 다음 ---
DAUM_EMAIL=your_id@daum.net
DAUM_PASSWORD=app_password_here
DAUM_FOLDERS=INBOX

# --- LLM (Gemini) ---
GEMINI_API_KEY=your_gemini_api_key
# LLM 교체 가능: 기본 gemini (LLM_MODEL 로 모델 지정)
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash

# --- 파이프라인 발행 모드 ---
# review(기본): 기사화 후 기자 UI 에서 검토/발행 / auto: 즉시 발행
PIPELINE_MODE=review

# --- Supabase (DB + Auth) ---
# DATABASE_URL 은 위 DB 섹션 참고(Session pooler 권장)
SUPABASE_URL=https://akwwzfuosclqrvunoveu.supabase.co
SUPABASE_ANON_KEY=eyJ...anon_public_key
SUPABASE_SERVICE_KEY=eyJ...service_role_key   # 계정 생성용(비밀!)
# 세션 쿠키 서명 키 — 길고 무작위한 값
SESSION_SECRET=change-me-to-a-long-random-string

# 테넌트 비밀번호 암호화 키 (Fernet). 생성: python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
CONFIG_ENC_KEY=change-me-fernet-key

# --- 파일 저장소 ---
# local(기본, 개발용) | supabase(배포용 — 어디서 돌려도 파일 유지)
STORAGE_BACKEND=local
STORAGE_BUCKET=files

# --- 발행 대상: ND소프트 신문 템플릿 (기본 atpaju) ---
# 다른 ND소프트 사이트면 도메인만 변경
NDSOFT_BASE_URL=https://www.atpaju.com
ATPAJU_ID=your_login_id
ATPAJU_PW=your_login_password
ATPAJU_USER_NAME=작업자
ATPAJU_USER_EMAIL=your_email@daum.net
ATPAJU_SECTION=S2N2
# 발행기 선택: 비우면 HTML 내보내기(안전). atpaju 로 해야 실제 사이트 발행
PUBLISHER=
# 실제 게시 스위치: 1 이면 진짜 등록, 비우면 dry-run(로그인·기사ID까지만)
ATPAJU_LIVE=
